{
  "alwaysThinkingEnabled": true,
  "autoUpdateChannel": "stable",
  "enabledPlugins": {
    "agent-browser@agent-browser": true,
    "claude-md-management@claude-plugins-official": true,
    "code-review@claude-plugins-official": true,
    "figma@claude-plugins-official": true,
    "laravel-simplifier@laravel": true,
    "superpowers@claude-plugins-official": true
  },
  "env": {
    "CLAUDE_DISABLE_AUTO_UPDATES": "1"
  },
  "extraKnownMarketplaces": {
    "agent-browser": {
      "source": {
        "repo": "vercel-labs/agent-browser",
        "source": "github"
      }
    },
    "laravel": {
      "source": {
        "repo": "laravel/agent-skills",
        "source": "github"
      }
    }
  },
  "mcpServers": {
    "cc-approvals": {
      "type": "sse",
      "url": "http://localhost:9753/mcp/sse"
    }
  },
  "permissionPromptTool": "mcp__cc-approvals__request_permission",
  "permissions": {
    "allow": [
      "Skill(ray-skill:*)",
      "Skill(php-guidelines-from-spatie:*)",
      "Skill(fix-github-issue:*)",
      "Skill(context7-auto-research:*)",
      "Skill(readability:*)",
      "Skill(agent-browser:*)",
      "Bash(gh:*)",
      "Bash(curl:*)",
      "Bash(composer:*)",
      "Bash(vendor/bin/phpunit:*)",
      "Bash(vendor/bin/pest:*)",
      "Bash(git:*)",
      "Bash(php artisan:*)",
      "Bash(npm:*)",
      "Bash(npx:*)",
      "Bash(yarn:*)",
      "Bash(pnpm:*)",
      "Bash(php:*)",
      "Bash(docker:*)",
      "Bash(docker-compose:*)",
      "Bash(make:*)",
      "Bash(brew:*)",
      "Bash(sed:*)",
      "Bash(cat:*)",
      "Bash(ls:*)",
      "Bash(grep:*)",
      "Bash(find:*)",
      "Bash(echo:*)",
      "Bash(mkdir:*)",
      "Bash(cp:*)",
      "Bash(mv:*)",
      "Bash(touch:*)",
      "Bash(chmod:*)",
      "Bash(pwd:*)",
      "Bash(which:*)",
      "Bash(whoami:*)",
      "Bash(date:*)",
      "Bash(wc:*)",
      "Bash(sort:*)",
      "Bash(uniq:*)",
      "Bash(head:*)",
      "Bash(tail:*)",
      "Bash(diff:*)",
      "Bash(awk:*)",
      "Bash(cut:*)",
      "Bash(tr:*)",
      "Bash(open:*)",
      "WebSearch",
      "WebFetch",
      "mcp__laravel-boost__*",
      "mcp__chrome-devtools__*"
    ],
    "defaultMode": "acceptEdits",
    "deny": [
      "Read(**/.env*)"
    ]
  },
  "skipDangerousModePermissionPrompt": true,
  "statusLine": {
    "command": "~/.claude/statusline.sh",
    "type": "command"
  }
}