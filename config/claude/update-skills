#!/usr/bin/env php
<?php
/**
 * Manage Claude skills from their source repositories.
 *
 * Usage:
 *   ./update-skills                          # update all tracked skills
 *   ./update-skills <name> ...               # update specific skills by name
 *   ./update-skills --list                   # list all skills and their status
 *   ./update-skills install <git-url>        # install new skill and add to manifest
 *     [--subdir <path>]                      #   subdirectory within the repo
 *     [--ref <branch|tag|sha>]               #   git ref (default: main)
 *     [--name <override>]                    #   override local skill name
 *   ./update-skills sync                     # add untracked skill dirs to manifest
 */

const BLUE   = "\033[0;34m";
const GREEN  = "\033[0;32m";
const YELLOW = "\033[1;33m";
const RED    = "\033[0;31m";
const RESET  = "\033[0m";
const BOLD   = "\033[1m";

$scriptDir = dirname(__FILE__);
$manifest  = $scriptDir . '/skills-manifest.json';
$skillsDir = $scriptDir . '/skills';

// ── helpers ───────────────────────────────────────────────────────────────────

function step(string $msg): void   { echo "  " . BLUE   . "➜" . RESET . " $msg\n"; }
function success(string $msg): void { echo "  " . GREEN  . "✓" . RESET . " $msg\n"; }
function warn(string $msg): void   { echo "  " . YELLOW . "⚠" . RESET . " $msg\n"; }
function error(string $msg): void  { fwrite(STDERR, "  " . RED . "✗" . RESET . " $msg\n"); }

function run(array $cmd, ?string $cwd = null): string
{
    $command = implode(' ', array_map('escapeshellarg', $cmd));
    if ($cwd) {
        $command = "cd " . escapeshellarg($cwd) . " && " . $command;
    }
    exec($command . ' 2>&1', $output, $code);
    if ($code !== 0) {
        throw new RuntimeException(implode("\n", $output) ?: "Command failed: $command");
    }
    return implode("\n", $output);
}

function isSha(string $ref): bool
{
    return strlen($ref) >= 7 && ctype_xdigit($ref);
}

function readSkillName(string $skillDir): ?string
{
    $skillMd = $skillDir . '/SKILL.md';
    if (!file_exists($skillMd)) {
        return null;
    }
    if (preg_match('/^name:\s*(.+)$/m', file_get_contents($skillMd), $m)) {
        return trim($m[1]);
    }
    return null;
}

function cloneRepo(string $url, string $ref, ?string $subdir, string $dest): string
{
    if ($subdir) {
        $args = ['git', 'clone', '--filter=blob:none', '--sparse', '--no-checkout'];
        if (!isSha($ref)) {
            array_push($args, '--branch', $ref, '--depth', '1');
        }
        array_push($args, $url, $dest);
        run($args);
        run(['git', 'sparse-checkout', 'set', '--cone', $subdir], $dest);
        run(['git', 'checkout', $ref], $dest);
        return $dest . '/' . $subdir;
    }

    $args = ['git', 'clone', '--depth', '1'];
    if (!isSha($ref)) {
        array_push($args, '--branch', $ref);
    }
    array_push($args, $url, $dest);
    run($args);
    if (isSha($ref)) {
        run(['git', 'checkout', $ref], $dest);
    }
    return $dest;
}

function copySkill(string $src, string $name, string $skillsDir): void
{
    $dst = $skillsDir . '/' . $name;
    if (is_dir($dst)) {
        run(['rm', '-rf', $dst]);
    }
    run(['rsync', '-a', '--exclude=.git', '--exclude=__pycache__', '--exclude=*.pyc', $src . '/', $dst]);
}

function loadManifest(string $path): array
{
    if (!file_exists($path)) {
        error("Manifest not found: $path");
        exit(1);
    }
    return json_decode(file_get_contents($path), true);
}

function saveManifest(array $manifest, string $path): void
{
    usort($manifest['skills'], fn($a, $b) => $a['name'] <=> $b['name']);
    file_put_contents($path, json_encode($manifest, JSON_PRETTY_PRINT | JSON_UNESCAPED_SLASHES) . "\n");
}

function tmpDir(): string
{
    $dir = sys_get_temp_dir() . '/claude-skills-' . uniqid();
    mkdir($dir, 0700, true);
    return $dir;
}

function removeTmpDir(string $dir): void
{
    if (is_dir($dir)) {
        run(['rm', '-rf', $dir]);
    }
}

// ── commands ──────────────────────────────────────────────────────────────────

function cmdList(array $manifest): void
{
    $tracked = array_filter($manifest['skills'], fn($s) => !empty($s['git']));
    $unknown = array_filter($manifest['skills'], fn($s) => empty($s['git']));

    usort($tracked, fn($a, $b) => $a['name'] <=> $b['name']);
    usort($unknown, fn($a, $b) => $a['name'] <=> $b['name']);

    echo "\n" . BOLD . "Tracked skills (" . count($tracked) . "):" . RESET . "\n";
    foreach ($tracked as $s) {
        $subdir = !empty($s['subdir']) ? " [{$s['subdir']}]" : '';
        $ref    = $s['ref'] ?? 'main';
        printf("  " . GREEN . "✓" . RESET . " %-40s %s%s @ %s\n", $s['name'], $s['git'], $subdir, $ref);
    }

    echo "\n" . BOLD . "Unknown source (" . count($unknown) . "):" . RESET . "\n";
    foreach ($unknown as $s) {
        $notes = !empty($s['notes']) ? " — {$s['notes']}" : '';
        echo "  " . YELLOW . "?" . RESET . " {$s['name']}$notes\n";
    }
    echo "\n";
}

function cmdUpdate(array $manifest, string $manifestPath, array $names, string $skillsDir): void
{
    if (!is_dir($skillsDir)) {
        mkdir($skillsDir, 0755, true);
    }

    $skills = $manifest['skills'];
    if ($names) {
        $known = array_column($skills, 'name');
        foreach (array_diff($names, $known) as $n) {
            error("$n: not in manifest");
        }
        $skills = array_filter($skills, fn($s) => in_array($s['name'], $names));
    }

    $ok = $skipped = $failed = 0;
    echo "\n" . BOLD . "Updating Claude skills" . RESET . "\n\n";

    $tmp = tmpDir();
    try {
        foreach ($skills as $skill) {
            $name = $skill['name'];
            $url  = $skill['git'] ?? null;

            if (!$url) {
                warn("$name: no git source, skipping");
                $skipped++;
                continue;
            }

            $ref    = $skill['ref'] ?? 'main';
            $subdir = $skill['subdir'] ?? null;
            $loc    = $url . ($subdir ? " [$subdir]" : '') . " @ $ref";
            step("$name  " . BLUE . $loc . RESET);

            try {
                $src = cloneRepo($url, $ref, $subdir, $tmp . '/' . $name);
                copySkill($src, $name, $skillsDir);
                success($name);
                $ok++;
            } catch (RuntimeException $e) {
                error("$name: " . $e->getMessage());
                $failed++;
            }
        }
    } finally {
        removeTmpDir($tmp);
    }

    echo "\n  " . GREEN . "$ok updated" . RESET . ", " . YELLOW . "$skipped skipped" . RESET . ", " . RED . "$failed failed" . RESET . "\n\n";

    if ($failed > 0) {
        exit(1);
    }
}

function cmdInstall(array $manifest, string $manifestPath, string $url, ?string $subdir, string $ref, ?string $nameOverride, string $skillsDir): void
{
    if (!is_dir($skillsDir)) {
        mkdir($skillsDir, 0755, true);
    }

    $known = array_column($manifest['skills'], 'name');

    echo "\n" . BOLD . "Installing skill" . RESET . "\n\n";
    step("Cloning $url" . ($subdir ? " [$subdir]" : '') . " @ $ref");

    $tmp = tmpDir();
    try {
        $dest = $tmp . '/_install';
        try {
            $src = cloneRepo($url, $ref, $subdir, $dest);
        } catch (RuntimeException $e) {
            error("Clone failed: " . $e->getMessage());
            exit(1);
        }

        $name = $nameOverride
            ?? readSkillName($src)
            ?? ($subdir ? basename($subdir) : basename(rtrim($url, '/')));

        if (in_array($name, $known)) {
            warn("'$name' already in manifest — updating entry and re-downloading");
        }

        step("Installing as '$name'");
        copySkill($src, $name, $skillsDir);
    } finally {
        removeTmpDir($tmp);
    }

    $manifest['skills'] = array_values(array_filter($manifest['skills'], fn($s) => $s['name'] !== $name));
    $manifest['skills'][] = [
        'name'   => $name,
        'git'    => $url,
        'subdir' => $subdir,
        'ref'    => $ref,
        'status' => 'tracked',
    ];

    saveManifest($manifest, $manifestPath);
    success("Installed '$name' and added to manifest");
    echo "\n";
}

function cmdSync(array $manifest, string $manifestPath, string $skillsDir): void
{
    if (!is_dir($skillsDir)) {
        warn("Skills directory does not exist");
        return;
    }

    $known     = array_column($manifest['skills'], 'name');
    $dirs      = array_filter(scandir($skillsDir), fn($d) => $d !== '.' && $d !== '..' && is_dir($skillsDir . '/' . $d));
    $untracked = array_values(array_filter($dirs, fn($d) => !in_array($d, $known)));
    sort($untracked);

    if (!$untracked) {
        success("All skill directories are already in the manifest");
        return;
    }

    echo "\n" . BOLD . "Untracked skill directories (" . count($untracked) . "):" . RESET . "\n\n";

    foreach ($untracked as $dirName) {
        $skillName = readSkillName($skillsDir . '/' . $dirName) ?? $dirName;
        $hint      = $skillName !== $dirName ? "  (SKILL.md name: $skillName)" : '';
        echo "  " . YELLOW . "+" . RESET . " $dirName$hint\n";

        $manifest['skills'][] = [
            'name'   => $dirName,
            'git'    => null,
            'status' => 'unknown',
            'notes'  => 'added by sync; set git source manually',
        ];
    }

    saveManifest($manifest, $manifestPath);
    $count = count($untracked);
    $entry = $count === 1 ? 'entry' : 'entries';
    echo "\n  Added $count $entry to manifest with status 'unknown'.\n";
    echo "  Edit $manifestPath to set git sources.\n\n";
}

// ── entry point ───────────────────────────────────────────────────────────────

$args     = array_slice($argv, 1);
$data     = loadManifest($manifest);

if (!$args || $args === ['--list']) {
    if ($args === ['--list']) {
        cmdList($data);
    } else {
        cmdUpdate($data, $manifest, [], $skillsDir);
    }
    exit(0);
}

if ($args[0] === '--list') {
    cmdList($data);
    exit(0);
}

if ($args[0] === 'sync') {
    cmdSync($data, $manifest, $skillsDir);
    exit(0);
}

if ($args[0] === 'install') {
    $rest = array_slice($args, 1);
    if (!$rest || str_starts_with($rest[0], '--')) {
        error("Usage: update-skills install <git-url> [--subdir <path>] [--ref <ref>] [--name <name>]");
        exit(1);
    }

    $url    = array_shift($rest);
    $subdir = $ref = $nameOverride = null;

    for ($i = 0; $i < count($rest); $i++) {
        match ($rest[$i]) {
            '--subdir' => $subdir      = $rest[++$i],
            '--ref'    => $ref         = $rest[++$i],
            '--name'   => $nameOverride = $rest[++$i],
            default    => (function () use ($rest, $i) {
                error("Unknown argument: {$rest[$i]}");
                exit(1);
            })(),
        };
    }

    cmdInstall($data, $manifest, $url, $subdir, $ref ?? 'main', $nameOverride, $skillsDir);
    exit(0);
}

// Positional args = skill names to update
cmdUpdate($data, $manifest, $args, $skillsDir);
